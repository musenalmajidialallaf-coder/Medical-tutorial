rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 3. Primitive Definition (Global Helpers)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'musen.almajidi.alallaf@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // 2. Validation Blueprints (Schema Guards)
    // ===============================================================
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.subscription in ['free', 'paid'] &&
             data.freeUploadsUsed is number && data.freeUploadsUsed >= 0 &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'] &&
             data.dialect is string && data.dialect.size() <= 100 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 128)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100));
    }

    function isValidPastLecture(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() <= 512 &&
             data.summary is string && data.summary.size() <= 50000 &&
             data.date is number;
    }

    function isValidFeedback(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.lectureTitle is string && data.lectureTitle.size() <= 512 &&
             data.type in ['up', 'down'] &&
             data.createdAt == request.time &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 5000));
    }

    function isValidPublicProfile(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'];
    }

    // ===============================================================
    // Match Blocks (The Fortress)
    // ===============================================================

    // Public Profiles for Leaderboard
    match /public_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isDocOwner(profileId) && isValidId(profileId) && isValidPublicProfile(incoming());
      allow update: if (isDocOwner(profileId) && isValidId(profileId) && isValidPublicProfile(incoming())) || isAdmin();
    }

    // User Data & Lectures
    match /users/{userId} {
      allow get: if isDocOwner(userId) || isAdmin();
      // list is restricted to protect metadata scraping
      allow list: if isAdmin(); 

      allow create: if isDocOwner(userId) && isValidId(userId) && 
                      isValidUserProfile(incoming()) && 
                      incoming().subscription == 'free'; // Force initial subscription to free
      
      allow update: if isAdmin() || (
        isDocOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && 
        incoming().uid == existing().uid &&
        incoming().subscription == existing().subscription // Prevent users from changing their own subscription level
      );

      match /lectures/{lectureId} {
        allow read: if isDocOwner(userId) || isAdmin();
        allow create: if isDocOwner(userId) && isValidId(lectureId) && isValidPastLecture(incoming());
        allow update: if isDocOwner(userId) && isValidId(lectureId) && isValidPastLecture(incoming()) && 
                       incoming().id == existing().id && incoming().uid == existing().uid;
        allow delete: if isDocOwner(userId) || isAdmin();
      }
    }

    // Admin Management
    match /admins/{adminEmail} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Feedbacks
    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(feedbackId) && isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
